# このファイルは環境変数のテンプレートです。
# 実際に使用する場合は .env にコピーして値を設定してください。
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────
# 必須: すべての項目が設定されていないと API Gateway が起動しません
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=demand_forecast
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme

# ── API Gateway ───────────────────────────────────────────
API_GATEWAY_PORT=8080
ML_SERVICE_URL=http://ml-service:8000

# ── ML Service ────────────────────────────────────────────
ML_SERVICE_PORT=8000

# モデル読み込みモード: local（デフォルト）または s3
# local: ml-service/models/ から直接読み込む（ローカル開発向け）
# s3   : 起動時に S3 からダウンロードして読み込む（ステージング・本番向け）
STORAGE_MODE=local

# ── S3 設定（STORAGE_MODE=s3 のときのみ必要）──────────────
AWS_REGION=ap-northeast-1
# 必須（STORAGE_MODE=s3 の場合）: 実際のバケット名に変更してください
S3_BUCKET_NAME=your-bucket-name

# S3 上のモデル成果物キー
# 設計: s3://<bucket>/demand-forecast/models/ 以下に配置する
S3_MODEL_KEY=demand-forecast/models/model.pkl
S3_ARTIFACTS_KEY=demand-forecast/models/artifacts.pkl

# ── Frontend ──────────────────────────────────────────────
# Frontend（React）から API Gateway へのリクエスト先 URL
VITE_API_BASE_URL=http://localhost:8080
